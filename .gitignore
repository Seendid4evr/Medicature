# =============================================
# Medicature — .gitignore
# =============================================

# ---- Sensitive Config ----
config/mail.php

# ---- Vendor / Dependencies (use Composer) ----
vendor/

# ---- Uploaded files by users ----
uploads/*
!uploads/.gitkeep

# ---- Archive & Backup files ----
archive/
archive.zip
*.zip
*.tar.gz

# ---- One-off / Junk files ----
sss/
diag.php
test_delete_debug.php

# ---- Python cache ----
__pycache__/
*.pyc

# ---- OS junk ----
.DS_Store
Thumbs.db
desktop.ini

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo
